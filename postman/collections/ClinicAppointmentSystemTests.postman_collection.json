    {
      "name": "patients",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "id": "c60353e9-960c-490a-b39c-416db92cada1",
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "id": "3dba9841-0edd-4cc7-814b-fde2f85054c0",
            "exec": [
              "// 1) Assert response status is 200",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// 2) Assert response time is below 1000ms",
              "pm.test(\"Response time is below 1000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});",
              "",
              "// 3) Assert response has JSON array",
              "let jsonData;",
              "try {",
              "    jsonData = pm.response.json();",
              "} catch (e) {",
              "    pm.test(\"Response is valid JSON\", function () {",
              "        pm.expect.fail(\"Response is not valid JSON: \" + e.message);",
              "    });",
              "    return;",
              "}",
              "",
              "pm.test(\"Response is a JSON array\", function () {",
              "    pm.expect(jsonData).to.be.an(\"array\");",
              "});",
              "",
              "// 4) If array is non-empty, validate each item has required properties",
              "if (Array.isArray(jsonData) && jsonData.length > 0) {",
              "    const emailRegex = /^[^\\\\s@]+@[^\\\\s@]+\\\\.[^\\\\s@]+$/;",
              "",
              "    pm.test(\"Each patient has id (number), firstName (string), lastName (string), email (string matching email regex)\", function () {",
              "        jsonData.forEach((patient, index) => {",
              "            pm.expect(patient, `Patient at index ${index} missing id`).to.have.property(\"id\").that.is.a(\"number\");",
              "            pm.expect(patient, `Patient at index ${index} missing firstName`).to.have.property(\"firstName\").that.is.a(\"string\");",
              "            pm.expect(patient, `Patient at index ${index} missing lastName`).to.have.property(\"lastName\").that.is.a(\"string\");",
              "            pm.expect(patient, `Patient at index ${index} missing email`).to.have.property(\"email\").that.is.a(\"string\");",
              "            pm.expect(patient.email, `Patient at index ${index} email does not match email format`).to.match(emailRegex);",
              "        });",
              "    });",
              "",
              "    // 5) Extract and save first patient's id to collection variable 'firstPatientId'",
              "    if (jsonData[0].id !== undefined && jsonData[0].id !== null) {",
              "        pm.collectionVariables.set(\"firstPatientId\", jsonData[0].id);",
              "    }",
              "}",
              "",
              "// 6) Validate JWT token - decode payload and assert id and username exist",
              "pm.test(\"JWT token payload contains id and username\", function () {",
              "    const token = \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwidXNlcm5hbWUiOiJhZG1pbiIsImZ1bGxOYW1lIjoiQWRtaW4gVXNlciIsImlhdCI6MTc2NTQ3MzIxNCwiZXhwIjoxNzY1NDc2ODE0fQ.Ac5aMo662CgPx-rONmcoGn_JsYYeIWMoDNA3QsVaerR0\";",
              "    ",
              "    // Decode JWT payload (base64url decode the middle part)",
              "    const parts = token.split(\".\");",
              "    pm.expect(parts.length, \"JWT should have 3 parts\").to.equal(3);",
              "    ",
              "    // Base64url decode the payload",
              "    let payload = parts[1];",
              "    // Replace base64url characters with base64 characters",
              "    payload = payload.replace(/-/g, \"+\").replace(/_/g, \"/\");",
              "    // Add padding if needed",
              "    while (payload.length % 4) {",
              "        payload += \"=\";",
              "    }",
              "    ",
              "    const decodedPayload = JSON.parse(atob(payload));",
              "    ",
              "    pm.expect(decodedPayload, \"JWT payload missing id\").to.have.property(\"id\");",
              "    pm.expect(decodedPayload, \"JWT payload missing username\").to.have.property(\"username\");",
              "});",
              "",
              "pm.test(\"Each patient has basic fields\", () => {",
              "  const patients = pm.response.json();",
              "  pm.expect(patients).to.be.an(\"array\");",
              "",
              "  const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;",
              "",
              "  patients.forEach((p, index) => {",
              "    pm.expect(p).to.have.property(\"id\").that.is.a(\"number\");",
              "    pm.expect(p).to.have.property(\"firstName\").that.is.a(\"string\");",
              "    pm.expect(p).to.have.property(\"lastName\").that.is.a(\"string\");",
              "    pm.expect(p).to.have.property(\"email\");",
              "",
              "    const email = String(p.email || \"\").trim();",
              "",
              "    pm.expect(",
              "      email,",
              "      `Patient at index ${index} email does not match email format`",
              "    ).to.match(emailRegex);",
              "  });",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
