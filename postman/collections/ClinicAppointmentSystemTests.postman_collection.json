    {
      "name": "login",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "533ae285-5c3c-4b99-a756-14eadc56e94f",
            "exec": [
              "// Graceful handling for non-JSON responses",
              "let jsonData;",
              "try {",
              "    jsonData = pm.response.json();",
              "} catch (e) {",
              "    pm.test(\"Response is valid JSON\", function () {",
              "        pm.expect.fail(\"Response is not valid JSON: \" + e.message);",
              "    });",
              "    return;",
              "}",
              "",
              "// Test 1: Assert status is 200",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Test 2: Validate response time is below 1000ms",
              "pm.test(\"Response time is below 1000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});",
              "",
              "// Test 3: Handle both single object and array responses",
              "if (Array.isArray(jsonData)) {",
              "    // If response is an array, validate each item",
              "    pm.test(\"Array response - each item has required properties\", function () {",
              "        jsonData.forEach((item, index) => {",
              "            pm.expect(item, `Item ${index} missing token`).to.have.property(\"token\").that.is.a(\"string\");",
              "            pm.expect(item, `Item ${index} missing user`).to.have.property(\"user\");",
              "            pm.expect(item.user, `Item ${index} missing user.id`).to.have.property(\"id\").that.is.a(\"number\");",
              "            pm.expect(item.user, `Item ${index} missing user.username`).to.have.property(\"username\").that.is.a(\"string\");",
              "        });",
              "    });",
              "",
              "    // Save token from first item if array",
              "    if (jsonData.length > 0 && jsonData[0].token) {",
              "        pm.environment.set(\"token\", jsonData[0].token);",
              "    }",
              "",
              "    // Check for firstPatientId and firstAppointmentId in array items",
              "    jsonData.forEach((item) => {",
              "        if (item.firstPatientId !== undefined) {",
              "            pm.environment.set(\"firstPatientId\", item.firstPatientId);",
              "        }",
              "        if (item.firstAppointmentId !== undefined) {",
              "            pm.environment.set(\"firstAppointmentId\", item.firstAppointmentId);",
              "        }",
              "    });",
              "} else {",
              "    // Single object response",
              "    pm.test(\"Response has token property (string)\", function () {",
              "        pm.expect(jsonData).to.have.property(\"token\").that.is.a(\"string\");",
              "    });",
              "",
              "    pm.test(\"Response has user.id property (number)\", function () {",
              "        pm.expect(jsonData).to.have.property(\"user\");",
              "        pm.expect(jsonData.user).to.have.property(\"id\").that.is.a(\"number\");",
              "    });",
              "",
              "    pm.test(\"Response has user.username property (string)\", function () {",
              "        pm.expect(jsonData.user).to.have.property(\"username\").that.is.a(\"string\");",
              "    });",
              "",
              "    // Save token to environment variable",
              "    if (jsonData.token) {",
              "        pm.environment.set(\"token\", jsonData.token);",
              "    }",
              "",
              "    // Save firstPatientId if present",
              "    if (jsonData.firstPatientId !== undefined) {",
              "        pm.environment.set(\"firstPatientId\", jsonData.firstPatientId);",
              "    }",
              "",
              "    // Save firstAppointmentId if present",
              "    if (jsonData.firstAppointmentId !== undefined) {",
              "        pm.environment.set(\"firstAppointmentId\", jsonData.firstAppointmentId);",
              "    }",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
