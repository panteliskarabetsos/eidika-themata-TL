    {
      "name": "appointments",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "0f3b45a9-6c09-4471-8255-463448289f80",
            "exec": [
              "// 1) Assert status 200 and JSON content-type",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Content-Type is application/json\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "// 2) Parse response body and assert it's an array with at least one item",
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Response is an array with at least one item\", function () {",
              "    pm.expect(jsonData).to.be.an(\"array\");",
              "    pm.expect(jsonData.length).to.be.at.least(1);",
              "});",
              "",
              "// Helper function to validate ISO 8601 date string",
              "function isValidISO8601Date(dateString) {",
              "    const date = new Date(dateString);",
              "    return !isNaN(date.getTime()) && typeof dateString === \"string\";",
              "}",
              "",
              "// 3) & 4) Validate each appointment object structure and date fields",
              "pm.test(\"Each appointment has valid structure and properties\", function () {",
              "    jsonData.forEach((appointment, index) => {",
              "        // Validate top-level properties",
              "        pm.expect(appointment).to.have.property(\"id\").that.is.a(\"number\");",
              "        pm.expect(appointment).to.have.property(\"dateTime\").that.is.a(\"string\");",
              "        pm.expect(appointment).to.have.property(\"durationMinutes\").that.is.a(\"number\");",
              "        pm.expect(appointment).to.have.property(\"reason\").that.is.a(\"string\");",
              "        pm.expect(appointment).to.have.property(\"status\").that.is.a(\"string\");",
              "        pm.expect(appointment).to.have.property(\"patientId\").that.is.a(\"number\");",
              "        pm.expect(appointment).to.have.property(\"createdAt\").that.is.a(\"string\");",
              "        pm.expect(appointment).to.have.property(\"updatedAt\").that.is.a(\"string\");",
              "",
              "        // Validate nested Patient object",
              "        pm.expect(appointment).to.have.property(\"Patient\").that.is.an(\"object\");",
              "        pm.expect(appointment.Patient).to.have.property(\"id\").that.is.a(\"number\");",
              "        pm.expect(appointment.Patient).to.have.property(\"firstName\").that.is.a(\"string\");",
              "        pm.expect(appointment.Patient).to.have.property(\"lastName\").that.is.a(\"string\");",
              "        pm.expect(appointment.Patient).to.have.property(\"phone\").that.is.a(\"string\");",
              "",
              "        // 4) Validate date fields parse as valid dates",
              "        pm.expect(isValidISO8601Date(appointment.dateTime), \"dateTime should be valid ISO 8601 date at index \" + index).to.be.true;",
              "        pm.expect(isValidISO8601Date(appointment.createdAt), \"createdAt should be valid ISO 8601 date at index \" + index).to.be.true;",
              "        pm.expect(isValidISO8601Date(appointment.updatedAt), \"updatedAt should be valid ISO 8601 date at index \" + index).to.be.true;",
              "    });",
              "});",
              "",
              "// 5) Ensure no appointment has durationMinutes <= 0",
              "pm.test(\"No appointment has durationMinutes <= 0\", function () {",
              "    jsonData.forEach((appointment, index) => {",
              "        pm.expect(appointment.durationMinutes, \"durationMinutes at index \" + index + \" should be greater than 0\").to.be.above(0);",
              "    });",
              "});",
              "",
              "// 6) Save notable values to environment variables",
              "if (jsonData.length > 0) {",
              "    const firstAppointment = jsonData[0];",
              "    ",
              "    if (firstAppointment.id !== undefined && firstAppointment.id !== null) {",
              "        pm.environment.set(\"firstAppointmentId\", firstAppointment.id);",
              "    }",
              "    ",
              "    if (firstAppointment.Patient && firstAppointment.Patient.id !== undefined && firstAppointment.Patient.id !== null) {",
              "        pm.environment.set(\"firstPatientId\", firstAppointment.Patient.id);",
              "    }",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
